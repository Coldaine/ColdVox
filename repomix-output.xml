    let (non_blocking_file, _guard) = tracing_appender::non_blocking(file_appender);
    let env_filter =
        EnvFilter::try_new(cli_level).unwrap_or_else(|_| EnvFilter::new("debug"));

    let file_layer = fmt::layer()
        .with_writer(non_blocking_file)
        .with_ansi(false)
        .with_target(true)
        .with_file(true)
