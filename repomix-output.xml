# Job Classification Configuration
# Used to determine resource allocation for parallel execution

job_classifications:
  heavy:
    # High resource consumption jobs
    patterns:
      - "cargo build"
      - "cargo test"
      - "cargo doc"
      - "integration.*test"
      - "e2e.*test"
      - "Xvfb"
