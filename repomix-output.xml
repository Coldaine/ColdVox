    cat > /tmp/ci-fs-monitor.service << 'EOF'
[Unit]
Description=CI Filesystem Monitor
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/inotifywait -m -r -e create,delete,modify /home/coldaine/.ssh /etc/sudoers.d /etc/passwd
