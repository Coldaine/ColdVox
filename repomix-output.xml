            let frame = self.frames[self.index].clone();
            self.index += 1;

            if let Some(delay) = self.frame_delay {
                tokio::time::sleep(delay).await;
            }

            Some(frame)
        } else {
            None
        }
    }

    pub fn remaining_frames(&self) -> usize {
        self.frames.len() - self.index
    }
