# Rust build artifacts
/target/
**/target/
**/*.rs.bk
*.pdb

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.kate-swp
*~
.DS_Store

# Debug and profiling
perf.data
perf.data.old
flamegraph.svg
*.profraw
*.profdata

# Environment and config
.env
.env.local
.venv/

# AI Agent Frameworks (BMAD, Claude, etc)
.bmad/
.claude/

# Logs
logs/
*.log

# PR review and temporary files
compile_errors.txt
pr_*.txt
prs*.txt

# CI agent working files (written by Gemini CLI during review jobs)
# NOTE: NOT gitignored — Gemini CLI respects .gitignore as a security boundary
# and will refuse to read/write files that match gitignore patterns.
# These files are auto-generated at runtime and never committed (CI doesn't commit).
# They are excluded via .git/info/exclude or manual cleanup instead.
_tmp_*.md

# Temporary files
tmp/
temp/
*.tmp
.artifacts/
__pycache__/
*.pyc

# OS files
Thumbs.db

# Whisper models and libraries (large binary files)
# Whisper models (vendored for CI reliability)
models/
!models/whisper-base.en/
!models/whisper-base.en/**
*.model
*.bin
*.zip
whisper.cpp-*/
# Exception for vendored dependencies
!vendor/**/*.zip

# ColdVox local run artifacts
# Keep directory structure but ignore contents
.coldvox/*
!.coldvox/.gitkeep
crates/app/.coldvox/*
!crates/app/.coldvox/.gitkeep

# Node.js dependencies
node_modules/
dist/

# Binary executables and archives
actionlint
actionlint.tar.gz
*.tar.gz

# Generated documentation
man/

# External tool documentation (actionlint, etc)
LICENSE.txt
/package.json
/package-lock.json
docs/README.md
docs/api.md
docs/checks.md
docs/config.md
docs/install.md
docs/reference.md
docs/usage.md
.omc/ 

# AI Agent working directories
.sisyphus/
_ext_refs/

# Generated metadata - do not commit
_open_issues.json
_open_prs.json
_repo_metadata.json
